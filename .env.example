# =============================================================================
# ZTP Server - Environment Variables
# Copy to .env and fill in your values. Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ztp
POSTGRES_USER=ztp
POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Dashboard API (Go)
# -----------------------------------------------------------------------------
API_PORT=8080
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY=24h

# -----------------------------------------------------------------------------
# OIDC / Azure AD
# Set OIDC_ENABLED=false to disable OIDC and use only local auth
# -----------------------------------------------------------------------------
OIDC_ENABLED=false
OIDC_ISSUER=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
OIDC_CLIENT_ID=YOUR_CLIENT_ID
OIDC_CLIENT_SECRET=YOUR_CLIENT_SECRET
OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/oidc/callback

# -----------------------------------------------------------------------------
# Python Renderer (Jinja2)
# -----------------------------------------------------------------------------
RENDERER_PORT=8001
RENDERER_URL=http://renderer:8001
# Path inside container where configs/ is mounted
TEMPLATE_DIR=/templates

# -----------------------------------------------------------------------------
# Kea DHCP
# -----------------------------------------------------------------------------
# Network interface Kea should listen on (host network mode)
KEA_DHCP_INTERFACE=*
# URL of the Kea Control Agent REST API (internal)
KEA_CTRL_AGENT_URL=http://kea:8000

# -----------------------------------------------------------------------------
# TFTP
# -----------------------------------------------------------------------------
TFTP_PORT=69
TFTP_ROOT=/tftpboot

# -----------------------------------------------------------------------------
# Syslog Receiver
# -----------------------------------------------------------------------------
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=514

# -----------------------------------------------------------------------------
# BIND DNS (optional)
# -----------------------------------------------------------------------------
BIND_FORWARDER=8.8.8.8
ZTP_DOMAIN=meriplexlabs.com
ZTP_NETWORK=192.168.1.0/24
