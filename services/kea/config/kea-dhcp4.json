{
  // ─── Kea DHCP4 — ZTP Server ─────────────────────────────────────────────────
  // Key things to configure before deploying:
  //   1. Subnet / pool to match your management network
  //   2. "routers" (gateway IP)
  //   3. ZTP_SERVER_IP — IP of this server, sent to devices as TFTP server + PnP target
  //   4. KEA_DHCP_INTERFACE — set via env var (entrypoint substitution)
  //
  // Vendor classification observations from packet captures:
  //   Cisco    → option 60 = "ciscopnp" (exact, lowercase)
  //              option 61 = serial number (e.g. FOC264437SK), type 0
  //   Juniper  → option 60 = "Juniper-<model>-<serial>" (serial embedded!)
  //              option 12 = serial number
  //   Aruba/HP → option 60 = "HP <model> <desc> dslforum.org" for ProCurve/AOS
  //              option 60 = "Aruba..." for AOS-CX
  //   Extreme  → option 60 NOT SENT — match by MAC OUI (00:04:96 or 00:e0:2b)
  //   Fortinet → option 60 = "Fortinet..." (unconfirmed, adjust if different)

  "Dhcp4": {
    "interfaces-config": {
      "interfaces": ["${KEA_DHCP_INTERFACE}"],
      "dhcp-socket-type": "udp"
    },

    "lease-database": {
      "type": "postgresql",
      "host": "${POSTGRES_HOST}",
      "port": ${POSTGRES_PORT},
      "name": "${POSTGRES_DB}",
      "user": "${POSTGRES_USER}",
      "password": "${POSTGRES_PASSWORD}"
    },

    "hosts-database": {
      "type": "postgresql",
      "host": "${POSTGRES_HOST}",
      "port": ${POSTGRES_PORT},
      "name": "${POSTGRES_DB}",
      "user": "${POSTGRES_USER}",
      "password": "${POSTGRES_PASSWORD}"
    },

    "valid-lifetime": 600,
    "renew-timer": 200,
    "rebind-timer": 400,

    // Option 43 is redefined as "string" so Cisco PnP data ("5A1N;B2;K4;I...;J8080")
    // can be set as a plain ASCII string with ${ZTP_SERVER_IP} substitution.
    // For Juniper, option 43 is sent with csv-format:false (raw hex), which Kea
    // honours per-entry regardless of the global type definition.
    // Option 150 (tftp-server-address) is the Juniper file server pointer.
    "option-def": [
      {
        "name": "vendor-encapsulated-options",
        "code": 43,
        "type": "string",
        "space": "dhcp4"
      },
      {
        "name": "tftp-server-address",
        "code": 150,
        "type": "ipv4-address",
        "space": "dhcp4"
      }
    ],

    "client-classes": [

      // ── Cisco ────────────────────────────────────────────────────────────────
      // option 60 = exactly "ciscopnp" (lowercase, confirmed from capture)
      // option 61 contains the serial number (type 0, not hardware-type).
      //
      // Option 43 Cisco PnP format: "5A1N;B2;K4;I<server>;J<port>"
      //   5A   = Cisco PnP sub-type identifier
      //   1N   = instance 1, non-secure
      //   B2   = HTTP (B3 = HTTPS)
      //   K4   = keepalive interval
      //   I... = ZTP API server IP or hostname
      //   J... = port (8080 = our Go API)
      //
      // The Cisco PnP agent will call: http://<server>:8080/pnp/HELLO
      // and negotiate config delivery via the PnP protocol.
      // For simple HTTP ZTP (no PnP), remove option 43 and use option 67 only.
      {
        "name": "vendor-cisco",
        "test": "option[60].hex == 'ciscopnp'",
        "option-data": [
          {
            "name": "tftp-server-name",
            "data": "${ZTP_SERVER_IP}"
          },
          {
            "name": "boot-file-name",
            "data": "cisco/base.cfg"
          },
          {
            // Cisco PnP discovery redirect — points device at the ZTP API server
            // Change ${ZTP_SERVER_IP} to the IP of this server
            "name": "vendor-encapsulated-options",
            "data": "5A1N;B2;K4;I${ZTP_SERVER_IP};J8080",
            "always-send": true
          }
        ]
      },

      // ── Juniper ──────────────────────────────────────────────────────────────
      // option 60 = "Juniper-<model>-<serial>"
      //   e.g. "Juniper-ex3400-24p-NW3620490200"
      // option 12 (hostname) = serial number (sent by switch during DHCP).
      //
      // option 150 = ZTP file server IP (Juniper reads this instead of option 66).
      // option 67 = per-device config path, set dynamically by the flex-option hook
      //             using the serial from option 12: "juniper/<serial>/config"
      // option 43 suboption 3 = transfer protocol "http" (TLV binary).
      //
      // The device fetches: http://<option-150>/juniper/<serial>/config (port 80)
      // The API identifies the device directly by serial from the URL — no source
      // IP lookup, so NAT between the switch and the server is not a problem.
      {
        "name": "vendor-juniper",
        "test": "substring(option[60].hex, 0, 7) == 'Juniper'",
        "option-data": [
          {
            "name": "tftp-server-address",
            "data": "${ZTP_SERVER_IP}"
          },
          {
            // Transfer protocol suboption only (suboption 3 = "http", 4 bytes)
            // The config-file-name (suboption 1) is set per-device by flex-option.
            "name": "vendor-encapsulated-options",
            "data": "030468747470",
            "csv-format": false,
            "always-send": true
          }
        ]
      },

      // ── Aruba AOS-CX / HP ProCurve ───────────────────────────────────────────
      // AOS-CX (6300M, 6400, etc.): option 60 starts with "Aruba"
      // HP ProCurve (legacy): option 60 starts with "HP "
      //
      // Config delivery is TFTP only — Aruba Central is required for HTTP ZTP.
      // The base config sets credentials + SSH so the device can be reached
      // after discovery. Full config is pushed from the dashboard.
      {
        "name": "vendor-aruba",
        "test": "substring(option[60].hex, 0, 5) == 'Aruba' or substring(option[60].hex, 0, 3) == 'HP '",
        "option-data": [
          {
            "name": "tftp-server-name",
            "data": "${ZTP_SERVER_IP}"
          },
          {
            "name": "boot-file-name",
            "data": "aruba/base.cfg"
          }
        ]
      },

      // ── Extreme Networks ──────────────────────────────────────────────────────
      // Extreme ExtremeXOS switches do NOT send option 60.
      // Match by MAC OUI instead:
      //   00:04:96  — most Summit/X-series (ExtremeXOS)
      //   00:e0:2b  — older Summit/BlackDiamond
      //
      // Extreme already sends option 66 + 67 with empty values in the DISCOVER,
      // explicitly requesting them. We fill them in here.
      {
        "name": "vendor-extreme",
        "test": "substring(hexstring(pkt4.mac, ':'), 0, 8) == '00:04:96' or substring(hexstring(pkt4.mac, ':'), 0, 8) == '00:e0:2b'",
        "option-data": [
          {
            "name": "tftp-server-name",
            "data": "${ZTP_SERVER_IP}"
          },
          {
            "name": "boot-file-name",
            "data": "extreme/autoinstall.xsf"
          }
        ]
      },

      // ── Fortinet ─────────────────────────────────────────────────────────────
      // FortiSwitch option 60 typically starts with "Fortinet" or "FortiSwitch".
      // Update the prefix if you observe a different value in a capture.
      {
        "name": "vendor-fortinet",
        "test": "substring(option[60].hex, 0, 8) == 'Fortinet' or substring(option[60].hex, 0, 11) == 'FortiSwitch'",
        "option-data": [
          {
            "name": "tftp-server-name",
            "data": "${ZTP_SERVER_IP}"
          },
          {
            "name": "boot-file-name",
            "data": "fortinet/autoinstall.conf"
          }
        ]
      }

    ],

    "subnet4": [
      {
        "id": 1,
        // ── Update these to match your management network ──────────────────
        "subnet": "10.144.10.0/24",
        "pools": [
          { "pool": "10.144.10.100 - 10.144.10.200" }
        ],
        // ─────────────────────────────────────────────────────────────────
        "option-data": [
          { "name": "routers",             "data": "10.144.10.1"  },
          { "name": "domain-name-servers", "data": "10.144.10.1"  },
          { "name": "domain-name",         "data": "${ZTP_DOMAIN}" }
          // Note: tftp-server-name (option 66) and boot-file-name (option 67)
          // are intentionally NOT set at the subnet level.
          // Each vendor class sets its own — a subnet-level value would
          // override or conflict with class-level values in some Kea versions.
        ],
        "reservations-global": false,
        "reservations-in-subnet": true,

        // ── DHCP relay ────────────────────────────────────────────────────
        // giaddr set by the relay agent — typically the switch's SVI IP on
        // the management VLAN (192.168.25.1). Kea uses this to match the
        // relayed packet to this subnet.
        "relay": {
          "ip-addresses": ["10.144.10.1"]
        }
      }
    ],

    "hooks-libraries": [
      {
        // lease4-get-all, lease4-get-by-hw-address, etc.
        "library": "/usr/lib/x86_64-linux-gnu/kea/hooks/libdhcp_lease_cmds.so"
      },
      {
        // statistic-get-all — used by the dashboard leases page
        "library": "/usr/lib/x86_64-linux-gnu/kea/hooks/libdhcp_stat_cmds.so"
      },
      {
        // flex-option: dynamically set option 67 (boot-file-name) per Juniper device
        // using the serial number from option 12 (hostname sent by the switch).
        // Result: "juniper/<serial>/config" e.g. "juniper/jx3623030103/config"
        // Non-Juniper clients are unaffected (expression returns '' → option not added).
        "library": "/usr/lib/x86_64-linux-gnu/kea/hooks/libdhcp_flex_option.so",
        "parameters": {
          "options": [
            {
              "code": 67,
              "add": "ifelse(substring(option[60].hex, 0, 7) == 'Juniper', concat(concat('juniper/', lcase(option[12].hex)), '/config'), '')"
            }
          ]
        }
      }
    ],

    "loggers": [
      {
        "name": "kea-dhcp4",
        "output-options": [
          { "output": "stdout" }
        ],
        "severity": "INFO",
        "debuglevel": 0
      }
    ],

    "control-socket": {
      "socket-type": "unix",
      "socket-name": "/var/run/kea/kea-dhcp4-ctrl.sock"
    }
  }
}
